<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <title>Moje stránka</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        .container {
            background: rgba(255, 255, 255, 0.1);
            padding: 40px;
            border-radius: 15px;
            text-align: center;
            backdrop-filter: blur(10px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
            max-width: 400px;
        }

        h1 {
            margin-bottom: 20px;
        }

        p {
            margin-bottom: 30px;
        }

        .btn {
            display: inline-block;
            padding: 12px 25px;
            border-radius: 25px;
            background: white;
            color: #764ba2;
            text-decoration: none;
            font-weight: bold;
            transition: 0.3s;
        }

        .btn:hover {
            background: #ddd;
            transform: scale(1.05);
        }
    </style>
</head>
<body>

<div class="container">
    <h1>Vítej na mé stránce</h1>
    <p>stiskněte odkaz a navštívíte mou druhou stránku.</p>

<!-- Jednoduchá navigace s jedním odkazem -->
<nav style="text-align:center; margin:20px;">
    <a href="https://github.com/leonardreedstein-dev/dve-stranky/blob/main/lennyho%20repozit" 
       style="display:inline-block; padding:10px 20px; 
              background:#4CAF50; color:white; text-decoration:none; 
              border-radius:8px; font-weight:bold;">
        Přejít na stránku
    </a>
</nav>
</body>
</html>
